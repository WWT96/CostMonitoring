{
  "anchor_text": "def _compute_sheet_metal_index",
  "description": "钣金白痴指数公式锁定",
  "module_name": "sheet_metal_logic",
  "relative_path": "sheet_metal_logic.py",
  "structure": {
    "required_assignments": [
      "_STEEL_DENSITY"
    ],
    "required_functions": [
      {
        "name": "_compute_sheet_metal_index"
      },
      {
        "name": "detect_sheet_metal_anomalies"
      },
      {
        "name": "run_sheet_metal_auto_research"
      }
    ]
  },
  "rules": [
    {
      "anchor_text": "def _compute_sheet_metal_index",
      "id": "sheet_metal_formula",
      "label": "钣金白痴指数公式必须存在",
      "mode": "contains_all",
      "patterns": [
        "_STEEL_DENSITY = 7.6",
        "def _compute_sheet_metal_index(",
        "denominator = (result[\"净重\"] / 1000.0) * _STEEL_DENSITY",
        "computed_index = result[\"出厂单价\"] / denominator.replace(0, pd.NA)"
      ],
      "severity": "error"
    },
    {
      "anchor_text": "def load_sheet_metal_steel_market_anchor",
      "id": "sheet_metal_public_steel_fetch_contract",
      "label": "生意社钢价实时抓取必须保留",
      "mode": "contains_all",
      "patterns": [
        "\"热轧板卷\": \"https://rejuan.100ppi.com/\"",
        "\"冷轧板\": \"https://lyb.100ppi.com/\"",
        "\"镀锌板\": \"https://dxb.100ppi.com/\"",
        "\"中厚板\": \"https://zhb.100ppi.com/\"",
        "session.trust_env = False",
        "_extract_100ppi_security_cookie",
        "_fetch_steel_market_html(source_url, session=session, timeout=timeout)",
        "_parse_price_quotes_from_html(html)"
      ],
      "severity": "error"
    },
    {
      "anchor_text": "def load_sheet_metal_steel_market_anchor",
      "id": "sheet_metal_public_steel_no_llm_fallback",
      "label": "生意社钢价禁止LLM回退",
      "mode": "forbid_any",
      "patterns": [
        "LLM 检索测试",
        "用 LLM 检索钢价",
        "source_mode",
        "llm_configs",
        "llm_completion_func",
        "_load_sheet_metal_steel_market_anchor_from_llm"
      ],
      "severity": "error"
    },
    {
      "anchor_text": "def calculate_non_material_coefficients",
      "id": "sheet_metal_non_material_formula_contract",
      "label": "钣金非材料系数公式必须锁定",
      "mode": "contains_all",
      "patterns": [
        "reasonable_mask = in_bounds",
        "material_price_per_kg = float(material_price_per_ton) / 1000.0",
        "material_cost = (data[\"重量\"] / 1000.0) * material_price_per_kg",
        "\"材料成本\": valid_material_cost.astype(float).round(4)",
        "valid_data[\"_单行非材料成本系数百分数\"] = ((valid_data[\"成本\"].astype(float) / valid_material_cost) - 1.0) * 100.0",
        "group_coefficients = valid_data.groupby(\"备件简称\")[\"_单行非材料成本系数百分数\"].transform(_mode_average_numeric)",
        "result.attrs[\"coefficient_unit\"] = \"percent\""
      ],
      "severity": "error"
    }
  ]
}
